NODE_ENV=development
PORT=5000

# Frontend origins (comma-separated for production)
CLIENT_URL=http://localhost:5173
FRONTEND_URLS=

# Auth
JWT_SECRET=replace_with_secure_random_value

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=car_rental
DB_USER=root
DB_PASSWORD=

# Redis (optional but recommended)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (required for OTP / forgot-password)
EMAIL_USER=
EMAIL_PASS=

# Pinata (if using IPFS upload)
PINATA_JWT=

# Disable MB scheduler unless configured
MB_SCHEDULER_ENABLED=false
