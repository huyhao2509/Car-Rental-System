{
  "name": "car-rental-system",
  "version": "1.0.0",
  "private": true,
  "description": "Car Rental System monorepo",
  "main": "index.js",
  "scripts": {
    "install:all": "pnpm install -r",
    "dev": "pnpm --parallel --filter ./car-rental-backend --filter ./car-rental-website run dev",
    "dev:backend": "pnpm --filter ./car-rental-backend run dev",
    "dev:website": "pnpm --filter ./car-rental-website run dev",
    "start:prod": "pnpm --filter ./car-rental-backend run start:prod",
    "start:backend": "pnpm --filter ./car-rental-backend run start:prod",
    "build:website": "pnpm --filter ./car-rental-website run build",
    "test": "echo \"No root test configured\" && exit 0"
  },
  "packageManager": "pnpm@9",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "overrides": {
      "@pinata/sdk>axios": "^0.30.3"
    }
  }
}
